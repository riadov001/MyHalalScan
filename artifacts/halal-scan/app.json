{
  "expo": {
    "name": "HalalScan",
    "slug": "myhalalscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "halal-scan",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0F0C",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F0C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.halalscan.app",
      "infoPlist": {
        "NSCameraUsageDescription": "HalalScan a besoin de la caméra pour scanner les codes-barres des produits alimentaires.",
        "NSSpeechRecognitionUsageDescription": "HalalScan utilise la synthèse vocale pour annoncer les résultats."
      }
    },
    "android": {
      "package": "com.halalscan.app",
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0F0C"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "HalalScan a besoin de la caméra pour scanner les codes-barres."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "5f3d61f3-9220-4561-9832-5882866b7347"
      }
    },
    "owner": "jatekapplications"
  }
}
